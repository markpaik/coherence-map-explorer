{
  "name": "coherence-map-explorer",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "3D WebGL knowledge-graph explorer of the Common Core math coherence map.",
  "scripts": {
    "data": "tsx scripts/build-graph.ts",
    "dev": "npm run data && vite",
