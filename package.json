    "three": "0.185.1",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "@types/sanitize-html": "^2.16.1",
    "@types/three": "^0.185.1",
    "d3-force-3d": "^3.0.6",
    "sanitize-html": "^2.17.6",
    "tsx": "^4.23.1",
    "typescript": "^5.9.0",
    "vite": "^7.0.0",
    "vitest": "^3.0.0"
  }
